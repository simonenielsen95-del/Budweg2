<Window x:Class="Budweg2._0.MainWindow"
        
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Budweg2._0"
        xmlns:vms="clr-namespace:Budweg2._0.VievModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" Background="#FF10BF10" Foreground="White" Height="59" Width="800" FontSize="36"><Run Text="                                "/><Run Language="da-dk" Text="B"/><Run Text="UDWEG"/></TextBlock>


        <TextBox x:Name="tbxItemNo" HorizontalAlignment="Left" Margin="115,152,0,0" TextWrapping="Wrap" Text="{Binding ItemNo }" VerticalAlignment="Top" Width="120" TextChanged="TextBox_TextChanged" RenderTransformOrigin="-0.738,0.698"/>
        <Label Content="Vare Nr.  " HorizontalAlignment="Left" Margin="51,144,0,0" VerticalAlignment="Top"/>

        <Label Content="Antal" HorizontalAlignment="Left" Margin="51,179,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbxQuantity" HorizontalAlignment="Left" Margin="115,187,0,0" TextWrapping="Wrap" Text="{Binding Quantity}" VerticalAlignment="Top" Width="120"/>


        <ListBox x:Name="ItemsListBox" Height="78" Width="338" DisplayMemberPath="ItemNo" SelectionChanged="ItemsListBox_SelectionChanged" RenderTransformOrigin="0.503,0.485" ItemsSource="{Binding OCItems}" Margin="400,148,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="196,92,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="Opret ny følgeseddel" FontSize="18"/>
        <Button x:Name="btnSaveNewDeliveryNote" Content="Opret" HorizontalAlignment="Left" Margin="600,299,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
